<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Title -->
        <TextView
            android:id="@+id/tvAppTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#58A6FF"
            android:layout_marginBottom="24dp"/>

        <!-- Connection Settings Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardConnection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#161B22"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pixhawk Connection"
                    android:textColor="#E6EDF3"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Pixhawk IP Address"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="8dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etHost"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="192.168.137.1"
                        android:inputType="text"
                        android:textColor="#E6EDF3"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="UDP Port"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPort"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="14550"
                        android:inputType="number"
                        android:textColor="#E6EDF3"/>
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Connect Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConnect"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Connect &amp; Stream"
            android:textSize="16sp"
            app:backgroundTint="#58A6FF"
            android:layout_marginBottom="16dp"/>

        <!-- Status -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Stopped"
            android:textColor="#8B949E"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCamera"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#161B22"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Camera Feed"
                    android:textColor="#E6EDF3"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <androidx.camera.view.PreviewView
                    android:id="@+id/previewCamera"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_marginBottom="12dp"
                    android:background="#0D1117" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/swVideoStream"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="UDP JPEG video to PC/GCS"
                    android:textColor="#E6EDF3" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="Video Host"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etVideoHost"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:text="192.168.137.1"
                        android:textColor="#E6EDF3" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="Video UDP Port"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etVideoPort"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:text="5600"
                        android:textColor="#E6EDF3" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/swLandingTarget"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:checked="false"
                    android:text="Send LANDING_TARGET"
                    android:textColor="#E6EDF3" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/swVisionPose"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:text="Send VISION_POSITION_ESTIMATE"
                    android:textColor="#E6EDF3" />

                <TextView
                    android:id="@+id/tvCamera"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="monospace"
                    android:text="Camera idle"
                    android:textColor="#8B949E"
                    android:textSize="12sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Data Display Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardData"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#161B22"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Telemetry (Debug)"
                    android:textColor="#E6EDF3"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tvMetrics"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No active stream"
                    android:textColor="#8B949E"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:id="@+id/tvGps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="GPS  --"
                    android:textColor="#58A6FF"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="8dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#21262D"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvGyro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="GYRO  --"
                    android:textColor="#3FB950"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="8dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#21262D"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvAcc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ACC   --"
                    android:textColor="#D29922"
                    android:textSize="12sp"
                    android:fontFamily="monospace"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
